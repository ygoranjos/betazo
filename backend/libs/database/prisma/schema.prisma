generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  wallet       Wallet?
  bets         Bet[]

  @@map("users")
}

model Wallet {
  id        String   @id @default(uuid())
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model HouseConfig {
  id                 String   @id @default(uuid())
  minBetAmount       Decimal  @map("min_bet_amount") @db.Decimal(18, 2)
  maxPayoutPerTicket Decimal  @map("max_payout_per_ticket") @db.Decimal(18, 2)
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("house_configs")
}

enum BetStatus {
  PENDING
  WON
  LOST
  CANCELLED
  VOID
}

model Bet {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  stake           Decimal   @db.Decimal(18, 2)
  combinedOdds    Decimal   @map("combined_odds") @db.Decimal(10, 4)
  potentialPayout Decimal   @map("potential_payout") @db.Decimal(18, 2)
  status          BetStatus @default(PENDING)
  selections      Json
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id])

  @@map("bets")
}

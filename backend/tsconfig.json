{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@betazo/database": ["libs/database/src/index.ts"],
      "@betazo/database/*": ["libs/database/src/*"],
      "@betazo/redis-cache": ["libs/redis-cache/src/index.ts"],
      "@betazo/redis-cache/*": ["libs/redis-cache/src/*"],
      "@betazo/kafka-client": ["libs/kafka-client/src/index.ts"],
      "@betazo/kafka-client/*": ["libs/kafka-client/src/*"]
    }
  }
}